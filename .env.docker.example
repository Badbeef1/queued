# Spotify OAuth — register at https://developer.spotify.com/dashboard
# Set redirect URI to: http://YOUR_HOST_IP:3000/auth/callback
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Replace YOUR_HOST_IP with your machine's LAN IP (e.g. 192.168.1.42)
# All three must use the SAME host and port (nginx serves everything on one port)
SPOTIFY_REDIRECT_URI=http://YOUR_HOST_IP:3000/auth/callback
APP_URL=http://YOUR_HOST_IP:3000
CORS_ORIGIN=http://YOUR_HOST_IP:3000

# Internal server port (don't change unless you modify docker-compose.yml)
PORT=4000

# Port exposed on the host machine (default: 3000)
WEB_PORT=3000
