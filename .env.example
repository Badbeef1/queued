# Spotify OAuth App
# Register at https://developer.spotify.com/dashboard
# Set redirect URI to: http://localhost:4000/auth/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4000/auth/callback

# App URLs
APP_URL=http://localhost:5173
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Optional: auto-create a default session on startup
# DEFAULT_SESSION_NAME=Home
